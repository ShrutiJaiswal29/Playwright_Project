pipeline {

agent any

stages {

stage('Clone Repository') {

steps {

git branch: 'main',
url: 'https://github.com/ShrutiJaiswal29/Playwright_Project'

}

}

stage('Install Dependencies') {

steps {

bat 'npm install'

bat 'npm install -D allure-commandline'

bat 'npx playwright install'

}

}

stage('Run Tests') {

steps {

bat 'npx playwright test'

}

}

stage('Generate Allure Report') {

steps {

bat 'npx allure-commandline generate allure-results --clean -o allure-report'

}

}

}

post {

always {

archiveArtifacts(
artifacts:'playwright-report/**',
allowEmptyArchive:true
)

archiveArtifacts(
artifacts:'allure-report/**',
allowEmptyArchive:true
)

archiveArtifacts(
artifacts:'reports/**',
allowEmptyArchive:true
)

}

success {

echo 'BUILD SUCCESS'

}

failure {

echo 'BUILD FAILED'

}

}

}
